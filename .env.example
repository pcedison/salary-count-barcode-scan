# 員工薪資計算系統 - 環境變數配置範本
# 複製此檔案為 .env 並填入實際數值

# ===========================================
# 基本應用程式設置
# ===========================================

# 執行環境 (development | production | test)
NODE_ENV=production

# 應用程式監聽端口
PORT=5000

# 會話安全金鑰 (請生成32字元以上隨機字串)
SESSION_SECRET=your_very_long_random_session_secret_key_minimum_32_characters

# ===========================================
# 資料庫設置 (請選擇其中一種方式)
# ===========================================

# 選項 A: Supabase 雲端資料庫 (推薦)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# 選項 B: 本地 PostgreSQL 資料庫
# DATABASE_URL=postgresql://app_user:your_password@localhost:5432/employee_salary_db

# ===========================================
# 資料庫連接池設置
# ===========================================

# 最小連接數
DB_POOL_MIN=2

# 最大連接數
DB_POOL_MAX=10

# 連接超時 (毫秒)
DB_CONNECTION_TIMEOUT=30000

# 查詢超時 (毫秒)
DB_QUERY_TIMEOUT=60000

# ===========================================
# 安全設置
# ===========================================

# 會話超時時間 (分鐘)
SESSION_TIMEOUT=60

# 會話安全設置 (HTTPS 環境請設為 true)
SESSION_SECURE=false

# 防止 XSS 攻擊
SESSION_HTTP_ONLY=true

# CSRF 防護
SESSION_SAME_SITE=lax

# 啟用資料加密
ENABLE_DATA_ENCRYPTION=true

# 加密金鑰 (請生成32字元隨機字串)
ENCRYPTION_KEY=your_32_character_encryption_key

# ===========================================
# 系統功能開關
# ===========================================

# 啟用自動備份
ENABLE_AUTO_BACKUP=true

# 啟用系統監控
ENABLE_MONITORING=true

# 啟用效能監控
ENABLE_PERFORMANCE_MONITORING=true

# 啟用錯誤追蹤
ENABLE_ERROR_TRACKING=true

# ===========================================
# 備份設置
# ===========================================

# 備份間隔 (小時)
BACKUP_INTERVAL_HOURS=24

# 保留備份檔案數量
MAX_BACKUP_FILES=30

# 備份儲存路徑
BACKUP_PATH=/var/backups/employee-salary

# 備份保留天數
BACKUP_RETENTION_DAYS=90

# ===========================================
# 日誌設置
# ===========================================

# 日誌等級 (debug | info | warn | error)
LOG_LEVEL=info

# 啟用檔案日誌
LOG_TO_FILE=true

# 日誌檔案路徑
LOG_FILE_PATH=/var/log/employee-salary/app.log

# 日誌檔案最大大小
LOG_MAX_SIZE=10MB

# 保留日誌檔案數量
LOG_MAX_FILES=5

# 啟用存取日誌
ACCESS_LOG_ENABLED=true

# 存取日誌格式
ACCESS_LOG_FORMAT=combined

# ===========================================
# 效能設置
# ===========================================

# 快取過期時間 (秒)
CACHE_TTL_SECONDS=300

# 最大記憶體使用量
MAX_MEMORY_USAGE=1GB

# 請求限制 (每分鐘)
RATE_LIMIT_PER_MINUTE=60

# API 請求超時 (毫秒)
API_TIMEOUT=30000

# ===========================================
# 監控與警報設置
# ===========================================

# 健康檢查端點
HEALTH_CHECK_ENDPOINT=/health

# 健康檢查間隔 (秒)
HEALTH_CHECK_INTERVAL=30

# 效能監控啟用
MONITOR_RESPONSE_TIME=true
MONITOR_MEMORY_USAGE=true
MONITOR_DB_CONNECTIONS=true

# 警報設置
ALERT_EMAIL=admin@your-company.com

# 記憶體使用率警報閾值 (%)
ALERT_MEMORY_THRESHOLD=80

# 磁碟使用率警報閾值 (%)
ALERT_DISK_THRESHOLD=90

# CPU 使用率警報閾值 (%)
ALERT_CPU_THRESHOLD=80

# ===========================================
# 薪資計算設置
# ===========================================

# 基本時薪 (新台幣)
BASE_HOURLY_RATE=119

# 加班費倍率 - 平日前2小時
OVERTIME_RATE_1=1.34

# 加班費倍率 - 平日超過2小時/假日
OVERTIME_RATE_2=1.67

# 標準工作時數 (小時)
STANDARD_WORK_HOURS=8

# 加班起算時數
OVERTIME_THRESHOLD=8

# ===========================================
# 勞健保設置
# ===========================================

# 勞保費率 (個人負擔)
LABOR_INSURANCE_RATE=0.105

# 健保費率 (個人負擔)
HEALTH_INSURANCE_RATE=0.0517

# 勞退提撥率 (雇主負擔)
PENSION_CONTRIBUTION_RATE=0.06

# ===========================================
# 外部服務設置 (選用)
# ===========================================

# Google Drive 備份 (選用)
GOOGLE_DRIVE_BACKUP=false
GOOGLE_DRIVE_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# 電子郵件服務 (選用)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=system@your-company.com

# Slack 通知 (選用)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ===========================================
# 開發/測試設置
# ===========================================

# 開發模式設置 (僅在 NODE_ENV=development 時使用)
DEV_AUTO_RELOAD=true
DEV_SHOW_ERRORS=true
DEV_CORS_ORIGIN=http://localhost:3000

# 測試資料庫 (僅在 NODE_ENV=test 時使用)
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_employee_db

# ===========================================
# 進階設置 (通常不需要修改)
# ===========================================

# 檔案上傳大小限制 (MB)
MAX_UPLOAD_SIZE=10

# 請求主體大小限制
MAX_REQUEST_SIZE=50mb

# 靜態檔案快取時間 (秒)
STATIC_CACHE_MAX_AGE=86400

# 跨來源資源共享設置
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# 信任代理設置 (反向代理環境)
TRUST_PROXY=false

# 時區設置
TZ=Asia/Taipei

# ===========================================
# 生產環境專用設置
# ===========================================

# SSL 設置 (生產環境)
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# 網域設置
DOMAIN=your-domain.com
SUBDOMAIN=salary

# CDN 設置 (選用)
CDN_URL=https://cdn.your-domain.com

# ===========================================
# 系統管理設置
# ===========================================

# 管理員預設密碼 (首次安裝後請立即修改)
ADMIN_DEFAULT_PIN=admin123

# 系統維護模式
MAINTENANCE_MODE=false

# 系統版本
SYSTEM_VERSION=1.0.0

# 最後更新時間
LAST_UPDATED=2025-06-03

# ===========================================
# 注意事項
# ===========================================

# 1. 請將此檔案重新命名為 .env
# 2. 填入實際的設定值，移除範例內容
# 3. 確保 .env 檔案已加入 .gitignore，避免上傳到版本控制
# 4. SESSION_SECRET 和 ENCRYPTION_KEY 必須使用強隨機字串
# 5. 生產環境請務必設定 SESSION_SECURE=true (需要 HTTPS)
# 6. 資料庫密碼請使用強密碼
# 7. 定期輪換敏感金鑰和密碼