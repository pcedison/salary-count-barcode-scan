# 員工薪資與掃碼打卡系統 V3 - 環境變數範本
# 複製此檔案為 .env，並填入實際數值。

# ===========================================
# 基本應用程式設置
# ===========================================
NODE_ENV=production
PORT=5000
SESSION_SECRET=replace-with-at-least-32-characters-for-production
DEFAULT_ADMIN_PIN=123456
SESSION_TIMEOUT=60
TRUST_PROXY=true
SESSION_SECURE=true
SESSION_SAME_SITE=lax
ALLOWED_ORIGINS=https://your-app.example.com
LOG_LEVEL=info

# ===========================================
# PostgreSQL / Supabase
# ===========================================

# 一般 PostgreSQL
DATABASE_URL=postgresql://app_user:password@db-host:5432/employee_salary_db

# Supabase session mode（後端長連線優先）
# DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Supabase transaction pooler（仍可用；repo 會自動停用 prepared statements）
# DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ===========================================
# AES 加密
# ===========================================
USE_AES_ENCRYPTION=false
ENCRYPTION_KEY=replace-with-at-least-32-characters
ENCRYPTION_SALT=replace-with-explicit-salt

# ===========================================
# LINE 打卡（選用）
# 若設定其中任一個，其他 4 個也必須同時設定
# ===========================================
# LINE_LOGIN_CHANNEL_ID=
# LINE_LOGIN_CHANNEL_SECRET=
# LINE_LOGIN_CALLBACK_URL=https://your-app.example.com/api/line/callback
# LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# LINE_MESSAGING_CHANNEL_SECRET=

# ===========================================
# 注意事項
# ===========================================
# 1. Zeabur 不要手動設定 PORT，平台會自動注入。
# 2. production 必須提供 SESSION_SECRET。
# 3. USE_AES_ENCRYPTION=true 時必須提供 ENCRYPTION_KEY。
# 4. 第一次正式上線前，請先對目標資料庫執行一次 npm run db:push。
